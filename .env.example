NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Newsletter → Beehiiv (wenn gesetzt, wird Supabase für Signups nicht mehr genutzt)
# Dashboard: Settings → Integrations → API — API Key mit Scope subscriptions:write
# Publication ID (V2): Prefix pub_ + UUID, z. B. pub_xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# (V1/roh sieht oft nur nach UUID aus — für diese App immer die V2-Form mit pub_ verwenden.)
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_your-publication-id
# Optional: mehrere List-IDs (kommagetrennt), nur wenn du Listen in beehiiv nutzt
# BEEHIIV_NEWSLETTER_LIST_IDS=
# BEEHIIV_SEND_WELCOME_EMAIL=false
# BEEHIIV_REACTIVATE_EXISTING=true

# Public reads / newsletter: API routes may still use the service role.
# Admin UI: uses anon key + Supabase Auth session cookies (see supabase/admin_auth_rls.sql).
# Bootstrap: create a user under Authentication, then:
#   insert into public.admin_users (user_id) values ('<auth.users.id>');
